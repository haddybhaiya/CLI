{
  "name": "@insforge/cli",
  "version": "0.1.80",
  "description": "InsForge CLI - Command line tool for InsForge platform",
  "type": "module",
  "bin": {
    "insforge": "dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "vitest run --passWithNoTests && eslint src/",
    "lint:fix": "eslint src/ --fix",
    "prepublishOnly": "npm run lint && npm run build",
    "test": "vitest run --passWithNoTests",
    "test:unit": "vitest run --passWithNoTests",
    "test:integration:real": "npm run build && vitest run src/integration/real-project.test.ts"
  },
  "keywords": [
    "insforge",
    "cli",
    "backend",
    "database",
    "storage",
    "functions"
  ],
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "@insforge/shared-schemas": "^1.1.52",
    "archiver": "^7.0.1",
    "cli-table3": "^0.6.5",
    "commander": "^13.1.0",
    "open": "^10.1.0",
    "picocolors": "^1.1.1",
    "posthog-node": "^5.28.9",
    "smol-toml": "^1.6.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/archiver": "^7.0.0",
    "@types/node": "^22.13.4",
    "eslint": "^10.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.56.0",
    "vitest": "^4.1.0"
  }
}
